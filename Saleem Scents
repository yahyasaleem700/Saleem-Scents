<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Saleem Scents</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-neutral-950 text-white font-sans">

  <header class="sticky top-0 z-50 border-b border-white/10 bg-neutral-950/90 backdrop-blur">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
      <div class="flex items-center gap-3">
        <img id="logoPreview" alt="Logo" class="hidden h-10 w-10 rounded-xl object-cover bg-neutral-800" />
        <div>
          <h1 class="text-2xl font-bold tracking-wide">SALEEM SCENTS</h1>
          <p class="text-xs uppercase tracking-[0.3em] text-neutral-400">Natural Perfumery</p>
        </div>
      </div>

      <label class="cursor-pointer rounded-xl border border-white/20 px-4 py-2 text-sm hover:border-white/40">
        Upload Logo
        <input type="file" accept="image/*" class="hidden" id="logoUpload" />
      </label>
    </div>
  </header>

  <section id="home" class="mx-auto grid max-w-7xl gap-12 px-6 py-24 lg:grid-cols-2 lg:items-center">
    <div>
      <p class="mb-4 text-sm uppercase tracking-[0.4em] text-neutral-400">Natural Perfumery Brand</p>

      <h2 class="mb-6 text-5xl font-bold leading-tight md:text-6xl">
        One winter fragrance in development.
      </h2>

      <p class="mb-8 max-w-xl text-lg leading-relaxed text-neutral-300">
        Saleem Scents is moving into natural perfumery, focusing on raw materials, balance, and depth. Currently working on a single winter fragrance project.
      </p>

      <div class="flex flex-wrap gap-4">
        <a href="#collection" class="rounded-2xl bg-white px-6 py-3 font-medium text-black transition hover:opacity-90">View Collection</a>
        <a href="#contact" class="rounded-2xl border border-white/20 px-6 py-3 transition hover:border-white/40">Contact</a>
      </div>
    </div>

    <div class="rounded-[2rem] border border-white/10 bg-gradient-to-br from-neutral-800 to-neutral-900 p-10 text-center">
      <h3 class="text-2xl font-semibold mb-2">Winter Project</h3>
      <p class="text-sm text-neutral-400">Natural composition • In development</p>
    </div>
  </section>

  <section id="collection" class="mx-auto max-w-7xl px-6 py-20">
    <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="text-4xl font-bold">Decants Collection</h2>
        <p class="text-sm text-neutral-400">Designer perfumes available for decanting</p>
      </div>

      <label class="cursor-pointer rounded-2xl border border-white/20 px-5 py-3 text-sm hover:border-white/40 w-fit">
        Upload Collection Image
        <input id="collectionUpload" type="file" accept="image/*" class="hidden" />
      </label>
    </div>

    <div class="rounded-[2rem] border border-white/10 bg-white/5 p-6">
      <img id="collectionPreview" alt="Collection" class="hidden w-full rounded-2xl object-cover" />
      <p id="collectionPlaceholder" class="text-neutral-400">No collection image uploaded yet.</p>

      <div class="mt-6 text-sm text-neutral-300">
        We offer decants from a curated selection of designer fragrances from our collection.
      </div>

      <a href="#contact" class="mt-6 inline-block rounded-2xl bg-white px-6 py-3 font-medium text-black">Inquire About Decants</a>
    </div>
  </section>

  <section id="contact" class="mx-auto max-w-4xl px-6 py-20">
    <div class="rounded-[2rem] border border-white/10 bg-white/5 p-10 text-center">
      <h2 class="mb-6 text-4xl font-bold">Contact</h2>

      <p class="mb-6 text-neutral-300">For inquiries or purchases, reach out below.</p>

      <div class="flex flex-col items-center gap-4">
        <a class="rounded-2xl bg-white px-6 py-3 font-medium text-black" href="https://instagram.com/saleemscents">@saleemscents</a>
        <a class="rounded-2xl border border-white/20 px-6 py-3" href="https://saleemscents.shop">saleemscents.shop</a>
        <a class="rounded-2xl border border-white/20 px-6 py-3" href="mailto:saleemscents.shop@gmail.com">saleemscents.shop@gmail.com</a>
      </div>
    </div>
  </section>

  <footer class="border-t border-white/10 py-8 text-center text-sm text-neutral-500">
    © 2026 Saleem Scents
  </footer>

  <script>
    const logoUpload = document.getElementById('logoUpload');
    const logoPreview = document.getElementById('logoPreview');

    if (logoUpload && logoPreview) {
      logoUpload.addEventListener('change', function (e) {
        const file = e.target.files && e.target.files[0];
        if (file) {
          const url = URL.createObjectURL(file);
          logoPreview.src = url;
          logoPreview.classList.remove('hidden');
        }
      });
    }

    const collectionUpload = document.getElementById('collectionUpload');
    const collectionPreview = document.getElementById('collectionPreview');
    const placeholder = document.getElementById('collectionPlaceholder');

    if (collectionUpload && collectionPreview && placeholder) {
      collectionUpload.addEventListener('change', function (e) {
        const file = e.target.files && e.target.files[0];
        if (file) {
          const url = URL.createObjectURL(file);
          collectionPreview.src = url;
          collectionPreview.classList.remove('hidden');
          placeholder.classList.add('hidden');
        }
      });
    }
  </script>

</body>
</html>
